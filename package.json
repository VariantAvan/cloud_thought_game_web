{
  "name": "web-cloud-game",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "workspaces": [
    "tools/asset-generator"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:standalone": "tsc && vite build --config vite.standalone.config.ts && node scripts/copy-play-html.mjs",
    "preview": "vite preview",
    "generate": "npm run generate --workspace=asset-generator",
    "remove-bg": "npm run remove-bg --workspace=asset-generator",
    "cloud-loop": "npm run cloud-loop --workspace=asset-generator"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-singlefile": "^2.2.0"
  }
}
